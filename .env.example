# AI 분석 기능에 사용할 API 키 (모두 선택 사항).
# 아래 중 하나 이상을 설정하지 않으면 AI 분석 기능은 자동으로 비활성화되고
# 나머지 기능은 정상 동작합니다.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# 사용할 AI 제공자를 명시적으로 지정 (anthropic | openai | gemini).
# 비워두면 위 키 중 설정된 것을 anthropic -> openai -> gemini 순서로 자동 선택합니다.
AI_PROVIDER=

# 제공자별 모델명 (선택, 기본값 사용 시 비워두세요)
ANTHROPIC_MODEL=
OPENAI_MODEL=
GEMINI_MODEL=

# AI provider API 호출 1건당 최대 대기 시간(초). 네트워크가 막혀 있거나
# 응답이 없는 provider 때문에 API KEY 체크 패널이 무한정 멈추는 것을 방지합니다.
AI_REQUEST_TIMEOUT_SECONDS=10
